name = "tamemj-support-ticket-mailer"
main = "src/index.ts"
compatibility_date = "2026-03-02"
workers_dev = true

[vars]
SUPPORT_EMAIL_TO = "noreply@tamemj.com"
SUPPORT_EMAIL_FROM = "TamemJ Support <tickets@tamemj.com>"
ALLOWED_ORIGIN = "https://tamemj.com"
TURNSTILE_EXPECTED_HOSTNAME = "tamemj.com"
RATE_LIMIT_MAX_PER_MINUTE = "6"

[[kv_namespaces]]
binding = "RATE_LIMIT_KV"
id = "<YOUR_RATE_LIMIT_KV_NAMESPACE_ID>"
